{
  "id": "01_vetores",
  "disciplina": "Álgebra Vetorial",
  "assunto": "Vetores",
  "ordem": 1,

  "teoria": {
    "resumo": "Um vetor possui módulo, direção e sentido, podendo ser representado por coordenadas.",

    "explicacao": "Um vetor pode ser representado no plano ou no espaço como (x, y) ou (x, y, z).\n\nMódulo:\n\n|v| = √(x² + y²) no plano\n|v| = √(x² + y² + z²) no espaço\n\nOperações:\n\n- Soma: soma componente a componente\n- Subtração: diferença componente a componente\n- Multiplicação escalar: multiplica cada componente\n\nVetor unitário:\n\nv/|v|\n\nDois vetores são:\n\n- Paralelos → um é múltiplo do outro\n- Ortogonais → formam 90°\n\nTambém podemos representar vetores como:\n\nv = xi + yj + zk",

    "intuicao": "Vetores representam deslocamentos no espaço.",

    "analogia": "Imagine uma seta indicando direção e intensidade — isso é um vetor.",

    "aplicacoes": [
      "Movimento em física",
      "Geometria analítica",
      "Engenharia e computação gráfica"
    ],

    "erros_comuns": [
      "Errar cálculo do módulo",
      "Confundir soma com multiplicação",
      "Não simplificar vetor unitário",
      "Confundir direção com sentido"
    ]
  },

  "questoes": [
    {
      "id": "q1",
      "nivel": "facil",
      "tipo": "multipla_escolha",
      "pergunta": "Qual é o módulo do vetor v = (6,8)?",
      "alternativas": [
        "10",
        "12",
        "14",
        "8"
      ],
      "resposta": "10",
      "explicacao": "|v| = √(6² + 8²) = √(36 + 64) = √100 = 10."
    },
    {
      "id": "q2",
      "nivel": "facil",
      "tipo": "multipla_escolha",
      "pergunta": "Dados u = (2,-1) e v = (3,4), qual é u + v?",
      "alternativas": [
        "(5,3)",
        "(1,-5)",
        "(6,3)",
        "(5,-3)"
      ],
      "resposta": "(5,3)",
      "explicacao": "Somando componente a componente: (2+3, -1+4) = (5,3)."
    },
    {
      "id": "q3",
      "nivel": "medio",
      "tipo": "multipla_escolha",
      "pergunta": "Qual é um vetor unitário na direção de v = (3,-4,12)?",
      "alternativas": [
        "(3/13, -4/13, 12/13)",
        "(1/13, -1/13, 12/13)",
        "(3/12, -4/12, 12/12)",
        "(3, -4, 12)"
      ],
      "resposta": "(3/13, -4/13, 12/13)",
      "explicacao": "|v| = 13 → vetor unitário = v/13."
    },
    {
      "id": "q4",
      "nivel": "medio",
      "tipo": "multipla_escolha",
      "pergunta": "Os vetores u = (2,4,6) e v = (1,2,3) são:",
      "alternativas": [
        "Paralelos",
        "Perpendiculares",
        "Ortogonais",
        "Reversos"
      ],
      "resposta": "Paralelos",
      "explicacao": "u = 2v → são múltiplos → vetores paralelos."
    },
    {
      "id": "q5",
      "nivel": "dificil",
      "tipo": "multipla_escolha",
      "pergunta": "Dados A(1,2,3) e B(4,6,9), qual é o vetor unitário na direção de AB?",
      "alternativas": [
        "(3/√61, 4/√61, 6/√61)",
        "(3/61, 4/61, 6/61)",
        "(1,1,1)",
        "(3,4,6)"
      ],
      "resposta": "(3/√61, 4/√61, 6/√61)",
      "explicacao": "AB = (3,4,6) e |AB| = √61 → vetor unitário = AB/|AB|."
    }
  ]
}
